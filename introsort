using System;

public static class IntroSort
{
    private const int InsertionSortThreshold = 16;

    public static void Sort<T>(T[] array) where T : IComparable<T>
    {
        if (array == null || array.Length <= 1) return;

        int depthLimit = 2 * (int)Math.Log(array.Length, 2) + 1;
        IntroSortImpl(array, 0, array.Length - 1, depthLimit);
    }

    private static void IntroSortImpl<T>(T[] array, int left, int right, int depthLimit)
        where T : IComparable<T>
    {
        int count = right - left + 1;

        if (count <= InsertionSortThreshold)
        {
            InsertionSort(array, left, right);
            return;
        }

        if (depthLimit == 0)
        {
            HeapSort(array, left, right);
            return;
        }

        int pivotIndex = Partition(array, left, right);

        IntroSortImpl(array, left, pivotIndex - 1, depthLimit - 1);
        IntroSortImpl(array, pivotIndex + 1, right, depthLimit - 1);
    }

    private static int Partition<T>(T[] array, int left, int right)
        where T : IComparable<T>
    {
        int mid = left + (right - left) / 2;

        if (array[mid].CompareTo(array[left]) < 0) Swap(array, left, mid);
        if (array[right].CompareTo(array[left]) < 0) Swap(array, left, right);
        if (array[right].CompareTo(array[mid]) < 0) Swap(array, mid, right);

        T pivot = array[mid];

        Swap(array, mid, right);

        int i = left - 1;
        int j = right;

        while (true)
        {
            do { i++; } while (array[i].CompareTo(pivot) < 0);
            do { j--; } while (array[j].CompareTo(pivot) > 0);

            if (i >= j) return j + 1;

            Swap(array, i, j);
        }
    }

    private static void InsertionSort<T>(T[] array, int left, int right)
        where T : IComparable<T>
    {
        for (int i = left + 1; i <= right; i++)
        {
            T key = array[i];
            int j = i - 1;

            while (j >= left && array[j].CompareTo(key) > 0)
            {
                array[j + 1] = array[j];
                j--;
            }
            array[j + 1] = key;
        }
    }

    private static void HeapSort<T>(T[] array, int left, int right)
        where T : IComparable<T>
    {
        int n = right - left + 1;
        for (int i = n / 2 - 1; i >= 0; i--)
        {
            Heapify(array, left, n, i);
        }

        for (int i = n - 1; i > 0; i--)
        {
            Swap(array, left, left + i);
            Heapify(array, left, i, 0);
        }
    }

    private static void Heapify<T>(T[] array, int start, int heapSize, int rootIndex)
        where T : IComparable<T>
    {
        int largest = rootIndex;
        int leftChild = 2 * rootIndex + 1;
        int rightChild = 2 * rootIndex + 2;

        if (leftChild < heapSize &&
            array[start + leftChild].CompareTo(array[start + largest]) > 0)
        {
            largest = leftChild;
        }

        if (rightChild < heapSize &&
            array[start + rightChild].CompareTo(array[start + largest]) > 0)
        {
            largest = rightChild;
        }

        if (largest != rootIndex)
        {
            Swap(array, start + rootIndex, start + largest);
            Heapify(array, start, heapSize, largest);
        }
    }

    private static void Swap<T>(T[] array, int i, int j)
    {
        (array[i], array[j]) = (array[j], array[i]);
    }

    public static void Sort<T>(T[] array, int index, int length)
        where T : IComparable<T>
    {
        if (index < 0 || length < 0 || index + length > array.Length)
            throw new ArgumentOutOfRangeException();

        if (length <= 1) return;

        int depthLimit = 2 * (int)Math.Log(length, 2) + 1;
        IntroSortImpl(array, index, index + length - 1, depthLimit);
    }
}